package com.mycompany.tugas1class_123230195;
//import supaya pachakge nya dipanggil
import NotSuperHero.NotGatotKaca;
import NotSuperHero.NotSpiderMan;


/**
 *
 * @author Nara Ganteng
 */
public class Tugas1Class_123230195 {

    public static void main(String[] args) {
        
    NotGatotKaca GK = new NotGatotKaca();
    
    
        // varian nya 0, soalnya aku spesial dan tidak ada di universe lain
        GK.busetidentitas("Nara Ganteng", 0);
        System.out.println("Identitas GatotKaca : " + GK.Nama);
        System.out.println("Jumlah Varian :" + GK.varian);
        GK.yapping();
        
        System.out.println("\n\n");
        
    NotSpiderMan SM = new NotSpiderMan();
        //Ruhul variannya banyak soalnya pasaran 
        SM.busetidentitas("Ruhul Emperan Sawah", 10000);
        System.out.println("Identitas Spiderman : " + SM.Nama);
        System.out.println("Jumlah Varian :" + SM.varian);
        SM.yapping();
    }
}
